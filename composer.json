{
    "name": "ikhsant/laravel-google-shared-drive",
    "description": "Google Shared Drive client integration for Laravel.",
    "license": "MIT",
    "authors": [
        {
            "name": "Ikhsan Thohir",
            "email": "ikhsanthohir@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2|^8.3|^8.4",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "google/apiclient": "^2.19"
    },
    "autoload": {
        "psr-4": {
            "Ikhsant\\LaravelGoogleSharedDrive\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ikhsant\\LaravelGoogleSharedDrive\\GoogleSharedDriveServiceProvider"
            ],
            "aliases": {
                "GoogleSharedDrive": "Ikhsant\\LaravelGoogleSharedDrive\\Facades\\GoogleSharedDrive"
            }
        }
    }
}
